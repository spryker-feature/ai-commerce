{
    "name": "spryker-feature/ai-commerce",
    "type": "library",
    "description": "AiCommerce module",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "spryker/ai-foundation": "^0.6.0",
        "spryker/catalog": "^5.10.0",
        "spryker/configuration": "^0.1.0",
        "spryker/glossary": "^3.0.0",
        "spryker/kernel": "^3.72.0",
        "spryker/log": "^3.0.0",
        "spryker/oms": "^11.0.0",
        "spryker/propel-orm": "^1.20.0",
        "spryker/sales": "^11.0.0",
        "spryker/symfony": "^3.0.0",
        "spryker/transfer": "^3.42.0",
        "spryker/twig-extension": "^1.0.0",
        "spryker/user": "^3.0.0"
    },
    "require-dev": {
        "spryker/code-sniffer": "*",
        "spryker/container": "*",
        "spryker/propel": "*",
        "spryker/shipment": "*",
        "spryker/testify": "*",
        "spryker/twig": "*"
    },
    "suggest": {
        "spryker/container": "ADD SUGGEST DESCRIPTION",
        "spryker/twig": "ADD SUGGEST DESCRIPTION"
    },
    "autoload": {
        "psr-4": {
            "SprykerFeature\\": "src/SprykerFeature/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/",
        "cs-fix": "phpcbf -p --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
