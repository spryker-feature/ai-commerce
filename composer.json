{
    "name": "spryker-feature/ai-commerce",
    "type": "library",
    "description": "AiCommerce module",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "spryker-shop/quick-order-page-extension": "^1.3.0",
        "spryker-shop/shop-ui": "^1.104.0",
        "spryker/ai-foundation": "^0.7.0",
        "spryker/application": "^3.46.0",
        "spryker/catalog": "^5.12.0",
        "spryker/category": "^5.24.0",
        "spryker/configuration": "^0.1.0",
        "spryker/discount": "^9.0.0",
        "spryker/glossary": "^3.0.0",
        "spryker/glossary-storage": "^1.0.0",
        "spryker/kernel": "^3.72.0",
        "spryker/locale": "^4.12.0",
        "spryker/log": "^3.0.0",
        "spryker/messenger": "^3.6.0",
        "spryker/oms": "^11.0.0",
        "spryker/product-management-extension": "^1.11.0",
        "spryker/propel-orm": "^1.20.0",
        "spryker/sales": "^11.0.0",
        "spryker/symfony": "^3.19.0",
        "spryker/transfer": "^3.42.0",
        "spryker/twig-extension": "^1.0.0",
        "spryker/user": "^3.0.0",
        "spryker/util-encoding": "^2.1.1"
    },
    "require-dev": {
        "spryker/code-sniffer": "*",
        "spryker/container": "*",
        "spryker/propel": "*",
        "spryker/router": "*",
        "spryker/shipment": "*",
        "spryker/testify": "*",
        "spryker/twig": "*"
    },
    "suggest": {
        "spryker/container": "When using BackofficeAssistant",
        "spryker/product": "When using AI-based product management features",
        "spryker/product-category": "When using category suggestions in product management.",
        "spryker/router": "Required for SearchByImageRouteProviderPlugin to register search by image routes in Yves.",
        "spryker/twig": "When using AiCommerceTwigPlugin"
    },
    "autoload": {
        "psr-4": {
            "SprykerFeature\\": "src/SprykerFeature/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/",
        "cs-fix": "phpcbf -p --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
