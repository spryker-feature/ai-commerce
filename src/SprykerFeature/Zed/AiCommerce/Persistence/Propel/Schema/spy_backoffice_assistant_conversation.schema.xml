<?xml version="1.0"?>
<database xmlns="spryker:schema-01"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          name="zed"
          xsi:schemaLocation="spryker:schema-01 https://static.spryker.com/schema-01.xsd"
          namespace="Orm\Zed\AiCommerce\Persistence"
          package="src.Orm.Zed.AiCommerce.Persistence">

    <table name="spy_backoffice_assistant_conversation" idMethod="native" phpName="SpyBackofficeAssistantConversation">
        <column name="id_backoffice_assistant_conversation" type="INTEGER" required="true" primaryKey="true" autoIncrement="true"/>
        <column name="fk_user" type="INTEGER" required="false"/>
        <column name="conversation_reference" type="VARCHAR" size="128" required="true"/>
        <column name="name" type="VARCHAR" size="255" required="true"/>
        <column name="agent" type="VARCHAR" size="255" required="false"/>
        <column name="user_selected_agent" type="VARCHAR" size="255" required="false"/>

        <unique name="spy_backoffice_assistant_conversation-unique-conversation_reference">
            <unique-column name="conversation_reference"/>
        </unique>

        <index name="spy_backoffice_assistant_conversation-index-fk_user">
            <index-column name="fk_user"/>
        </index>

        <foreign-key name="spy_backoffice_assistant_conversation-fk_user" foreignTable="spy_user" phpName="User" refPhpName="BackofficeAssistantConversation" onDelete="SET NULL">
            <reference local="fk_user" foreign="id_user"/>
        </foreign-key>

        <behavior name="timestampable"/>
    </table>

</database>
