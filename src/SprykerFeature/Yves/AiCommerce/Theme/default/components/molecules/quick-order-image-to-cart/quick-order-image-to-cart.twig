{% extends model('component') %}

{% define config = {
    name: 'quick-order-image-to-cart',
    tag:  'quick-order-image-to-cart',
} %}

{% define data = {
    form: required,
    supportedImageExtensions: [],
} %}

{% define attributes = {
    'input-file-id': data.form.children.uploadImageOrder.vars.id,
    'max-file-size': data.form.vars.maxFileSizeInBytes | default(0),
    'file-size-error-message': 'ai-commerce.quick-order-image-to-cart.image-order.errors.file-too-large' | trans,
} %}

{% block body %}
    <div class="{{ config.name }}__content">
        {% block title %}
            <h5 class="{{ config.name }}__title spacing-bottom">{{ 'ai-commerce.quick-order-image-to-cart.image-upload.title' | trans }}</h5>
        {% endblock %}

        {% block text %}
            {% if data.supportedImageExtensions is not empty %}
                {% set imageExtensions = data.supportedImageExtensions | join(', ') | upper %}
                <p>{{ 'ai-commerce.quick-order-image-to-cart.image-upload.description' | trans({'%formats%': imageExtensions}) | raw }}</p>
            {% endif %}
        {% endblock %}

        {% block imageOrderForm %}
            {% embed molecule('form') with {
                modifiers: ['browse-file'],
                data: {
                    form: data.form,
                    enableStart: false,
                    enableEnd: false,
                },
                embed: {
                    parentClass: config.name,
                    parentJsClass: config.jsName,
                },
            } only %}

                {% block fields %}
                    {{ parent() }}
                    <label class="label label--browse-file spacing-bottom spacing-bottom--reset {{ embed.parentJsClass }}__browse-file"
                           for="{{ data.form.children.uploadImageOrder.vars.id }}">
                        <span class="{{ embed.parentClass }}__browse-file-info">
                            {% include atom('icon') with {
                                class: 'spacing-bottom',
                                modifiers: ['browse-file'],
                                data: {
                                    name: 'browse-file',
                                },
                            } only %}

                            <span class="{{ embed.parentClass }}__file-select text-center">
                                <span class="{{ embed.parentJsClass }}__file-select">
                                    {{ 'ai-commerce.quick-order-image-to-cart.image-upload.browse-file' | trans }}
                                </span>

                                {% include atom('icon') with {
                                    class: 'is-hidden ' ~ embed.parentJsClass ~ '__remove-file',
                                    modifiers: ['small', 'remove-file'],
                                    data: {
                                        name: 'remove',
                                    },
                                } only %}
                            </span>
                        </span>
                    </label>
                {% endblock %}
            {% endembed %}
        {% endblock %}

        {% block button %}
            <button type="submit" name="uploadImage" class="button button--success spacing-top spacing-top--big">
                {{ 'ai-commerce.quick-order-image-to-cart.image-upload.button.upload' | trans }}
            </button>
        {% endblock %}
    </div>
{% endblock %}
