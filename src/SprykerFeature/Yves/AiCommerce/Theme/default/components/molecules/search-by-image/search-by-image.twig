{% extends model('component') %}

{% define config = {
    name: 'search-by-image',
    tag: 'search-by-image',
} %}

{% define data = {
    form: required,
    dataSearchId: '',
    formAction: path('search-by-image'),
} %}

{% define attributes = {
    'max-file-size-bytes': data.form.image.vars.attr['data-max-file-size'],
    'data-error-invalid-file-size': 'ai_commerce.error.file.size.invalid' | trans,
} %}

{% block extraClass %}
    {{ config.jsName }}--{{ data.dataSearchId }}
{% endblock %}

{% block searchByFilePopupContent %}
    {% include molecule('search-by-file-image', 'AiCommerce') with {
        attributes: {
            'data-parent': "#{config.jsName}--#{data.dataSearchId}",
            'data-parent-popup': "#{config.name}__search-by-file-popup--#{data.dataSearchId}",
            'max-file-size-bytes': data.form.image.vars.attr['data-max-file-size'],
            'allowed-file-types': data.form.image.vars.attr['accept'],
        },
    } only %}
{% endblock %}

{% block searchByPhotoPopupContent %}
    {% include molecule('search-by-photo-image', 'AiCommerce') with {
        attributes: {
            'data-parent': "#{config.jsName}--#{data.dataSearchId}",
            'data-parent-popup': "#{config.name}__search-by-photo-popup--#{data.dataSearchId}",
        },
    } only %}
{% endblock %}

{% block body %}
    {% set imageField = data.form.image %}
    {% set tokenField = data.form._token %}

    {% set triggerButtonClassname = "search-by-image__popup-trigger search-by-image__popup-trigger--#{data.dataSearchId} button button--hollow" %}

    {% set triggerButtonPhotoPopupTriggerClassname = "js-search-by-image__photo-popup-trigger--#{data.dataSearchId}" %}
    {% set triggerButtonFilePopupTriggerClassname = "js-search-by-image__file-popup-trigger--#{data.dataSearchId}" %}

    {% block triggerFileButton %}
        <button type="button" class="{{ config.jsName }}__btn-search-by-file {{ triggerButtonClassname }} {{ triggerButtonFilePopupTriggerClassname }}">
            {% include atom('icon') with {
                data: { name: 'visual-search' },
            } only %}
        </button>
    {% endblock %}

    {% block triggerPhotoButton %}
        <button type="button" class="{{ config.jsName }}__btn-search-by-photo {{ triggerButtonClassname }} {{ triggerButtonPhotoPopupTriggerClassname }} is-hidden">
            {% include atom('icon') with {
                data: { name: 'visual-search' },
            } only %}
        </button>
    {% endblock %}

    <input class="{{ config.name }}__file-input {{ config.jsName }}__file-input"
            type="file" name="{{ imageField.vars.full_name }}"
            accept="{{ imageField.vars.attr.accept }}">

    <input class="{{ config.name }}__token {{ config.jsName }}__token"
            type="hidden" name="{{ tokenField.vars.full_name }}"
            value="{{ tokenField.vars.value }}">

    {% include molecule('ajax-provider') with {
        class: config.jsName ~ '__ajax-provider',
        attributes: {
            url: data.formAction,
            method: 'POST',
            'response-type': 'json',
        },
    } only %}

    {% block searchByFilePopup %}
        {% include molecule('main-popup') with {
            class: "#{config.name}__search-by-file-popup #{config.name}__search-by-file-popup--#{data.dataSearchId}",
            data: {
                title: 'ai_commerce.search_by_image.form.image.label' | trans,
                content: block('searchByFilePopupContent'),
            },
            attributes: {
                'content-id': "search-by-file__main-popup--#{data.dataSearchId}",
                'trigger-class-name': triggerButtonFilePopupTriggerClassname,
                'has-content-mount': true,
            },
        } only %}
    {% endblock %}

    {% block searchByPhotoPopup %}
        {% include molecule('main-popup') with {
            class: "#{config.name}__search-by-photo-popup #{config.name}__search-by-photo-popup--#{data.dataSearchId}",
            modifiers: ['camera-view'],
            data: {
                title: 'ai_commerce.search_by_image.form.image.label' | trans,
                content: block('searchByPhotoPopupContent'),
            },
            attributes: {
                'content-id': "search-by-photo__main-popup--#{data.dataSearchId}",
                'trigger-class-name': triggerButtonPhotoPopupTriggerClassname,
                'has-content-mount': true,
            },
        } only %}
    {% endblock %}
{% endblock %}
